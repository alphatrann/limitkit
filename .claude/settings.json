{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "node \"C:/Users/MS/projects/limitkit/.claude/hooks/block-destructive-git.js\"",
            "if": "Bash(git *)",
            "timeout": 10
          },
          {
            "type": "command",
            "command": "node \"C:/Users/MS/projects/limitkit/.claude/hooks/block-push-to-protected-branch.js\"",
            "if": "Bash(git push*)",
            "timeout": 10
          },
          {
            "type": "command",
            "command": "node \"C:/Users/MS/projects/limitkit/.claude/hooks/changeset-reminder.js\"",
            "if": "Bash(gh pr create*)",
            "timeout": 15
          },
          {
            "type": "command",
            "command": "node \"C:/Users/MS/projects/limitkit/.claude/hooks/ensure-test-containers.js\"",
            "timeout": 30
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "node \"C:/Users/MS/projects/limitkit/.claude/hooks/format-and-lint.js\"",
            "timeout": 20
          }
        ]
      }
    ]
  }
}
