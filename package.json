{
  "name": "limitkit",
  "version": "1.1.0",
  "private": true,
  "description": "LimitKit is a lightweight Node.js library that enables rate-limiting in a flexible and intuitive for developers.",
  "repository": {
    "type": "git",
    "url": "https://github.com/alphatrann/limitkit"
  },
  "author": "Alpha Tran",
  "license": "MIT",
  "packageManager": "yarn@4.13.0",
  "workspaces": [
    "packages/**"
  ],
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev",
    "test": "turbo run test",
    "typecheck": "turbo run typecheck",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "changeset": "changeset",
    "version-packages": "changeset version"
  },
  "devDependencies": {
    "@changesets/cli": "^2.30.0",
    "@eslint/js": "^10.0.1",
    "@types/jest": "^30.0.0",
    "eslint": "^10.7.0",
    "eslint-config-prettier": "^10.1.8",
    "jest": "^30.2.0",
    "prettier": "^3.9.5",
    "ts-jest": "^29.4.6",
    "tsup": "^8.5.1",
    "turbo": "^2.8.14",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.63.0"
  }
}
